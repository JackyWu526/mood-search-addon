{
  "manifest_version": 2,
  "name": "Mood Search - 心情搜索",
  "version": "1.0.0",
  "description": "根据你的心情定制搜索体验，让搜索更懂你",
  "author": "JackyWu526",
  "homepage_url": "https://github.com/JackyWu526/mood-search-addon",
  
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "心情搜索",
    "default_popup": "popup/popup.html",
    "theme_icons": [{
      "light": "icons/icon-48.png",
      "dark": "icons/icon-48.png",
      "size": 48
    }]
  },
  
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "search"
  ],
  
  "background": {
    "scripts": ["background/background.js"]
  },
  
  "browser_specific_settings": {
    "gecko": {
      "id": "mood-search@jackywu526.github.io",
      "strict_min_version": "57.0"
    }
  },
  
  "data_collection_permissions": {
    "collects_data": false,
    "description": "此扩展不收集任何用户数据"
  }
}
